{
  "name": "ai-chat",
  "version": "1.0.0",
  "description": "模块化、可解耦的 AI 聊天框架，支持多平台、多 LLM、工具调用",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:ui && tsc",
    "build:ui": "cd web-ui && npm run build",
    "dev:ui": "cd web-ui && npm run dev",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "npm install && cd web-ui && npm install"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "grammy": "^1.41.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
